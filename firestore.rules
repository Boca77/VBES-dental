rules_version = '2';

// DentalVBES Firestore Security Rules
// Paste into: Firebase console -> Firestore Database -> Rules -> Publish
//
// Model:
//   - Appointments are private patient data: only the admin (signed in with
//     email/password) may read, update or delete them.
//   - Public visitors are signed in anonymously and may CREATE a booking
//     REQUEST (status "pending"), with validated fields and a per-visitor
//     rate cap enforced via the /throttles/{uid} document.
service cloud.firestore {
  match /databases/{database}/documents {

    // The admin logs in with email/password; anonymous visitors do not.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    match /appointments/{ref} {
      allow read, update, delete: if isAdmin();

      allow create: if isAdmin() || (
        request.auth != null
        && request.resource.data.status == 'pending'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasOnly(
            ['ref','service','date','time','name','phone','email','notes','created','source','status','createdBy'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 120
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 500
        && request.resource.data['service'] is string
        && request.resource.data.date is string
        && request.resource.data.time is string
      );
    }

    // Per-visitor rate cap. A booking is written in the same atomic batch as an
    // update to this doc; if the cooldown below hasn't elapsed, this write is
    // rejected and the whole batch (including the booking) is rolled back.
    match /throttles/{uid} {
      allow read: if false;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['last'])
        && request.resource.data.last == request.time
        && (resource == null
            || resource.data.last < request.time - duration.value(60, 's'));
    }
  }
}
