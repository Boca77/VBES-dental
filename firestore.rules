rules_version = '2';

// DentalVBES Firestore Security Rules
// Paste into: Firebase console -> Firestore Database -> Rules -> Publish
//
// Model:
//   - Appointments are private patient data: only the admin (signed in with
//     email/password) may read, update or delete them.
//   - Public visitors are signed in anonymously and may CREATE a booking
//     REQUEST (status "pending"), with validated fields (including a valid
//     Macedonian mobile phone) and a per-visitor rate cap enforced via the
//     /throttles/{uid} document.
service cloud.firestore {
  match /databases/{database}/documents {

    // The admin logs in with email/password; anonymous visitors do not.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    // Valid Macedonian mobile number (mirrors isValidMkMobile in shared.js):
    //   national 07X NNNNNN or international +3897X NNNNNN, X in {0,1,2,5,6,7,8}.
    function isValidMkMobile(p) {
      return p is string && p.matches('^(\\+389|0)7[0125678][0-9]{6}$');
    }

    match /appointments/{ref} {
      allow read, update, delete: if isAdmin();

      allow create: if isAdmin() || (
        request.auth != null
        && request.resource.data.status == 'pending'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasOnly(
            ['ref','service','date','time','name','phone','email','notes','created','source','status','createdBy'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30
        && isValidMkMobile(request.resource.data.phone)
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 120
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 500
        && request.resource.data['service'] is string
        && request.resource.data.date is string
        && request.resource.data.time is string
      );
    }

    // Public, PII-free booked-slot index (one doc per date, id = "YYYY-MM-DD").
    // Anyone may READ it so the public booking calendar can show taken/free
    // times. Anonymous visitors may only APPEND their own slot (in the same
    // atomic batch as their rate-limited booking) and can never clear or
    // shrink a day. The admin rebuilds or removes a day's index outright.
    match /availability/{date} {
      allow read: if true;

      allow write: if isAdmin();

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['date','times'])
        && request.resource.data.date == date
        && request.resource.data.times is list
        && request.resource.data.times.size() <= 1;

      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(['date','times'])
        && request.resource.data.date == date
        && request.resource.data.times is list
        && request.resource.data.times.hasAll(resource.data.times)
        && request.resource.data.times.size() <= resource.data.times.size() + 1;
    }

    // Per-visitor rate cap. A booking is written in the same atomic batch as an
    // update to this doc; if the cooldown below hasn't elapsed, this write is
    // rejected and the whole batch (including the booking) is rolled back.
    match /throttles/{uid} {
      allow read: if false;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['last'])
        && request.resource.data.last == request.time
        && (resource == null
            || resource.data.last < request.time - duration.value(60, 's'));
    }
  }
}
